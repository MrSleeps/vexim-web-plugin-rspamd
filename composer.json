{
    "name": "mrsleeps/vexim-web-plugin-rspamd",
    "description": "RSpamd Plugin for VExim Web UI",
    "type": "filament-plugin",
    "license": "GPL-3.0-only",
    "authors": [
        {
            "name": "Mr Sleeps"
        }
    ],
    "require": {
        "php": "^8.4",
        "filament/filament": "^5.0",
        "illuminate/support": "^13.0",
        "mrsleeps/vexim-web-plugin-rspamd-core": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "VEximweb\\Plugin\\RSpamd\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "VEximweb\\Plugin\\RSpamd\\RSpamdServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
